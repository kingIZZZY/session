{
    "name": "hypervel/session",
    "type": "library",
    "description": "The session package for Hypervel.",
    "license": "MIT",
    "keywords": [
        "php",
        "hyperf",
        "session",
        "swoole",
        "hypervel"
    ],
    "authors": [
        {
            "name": "Albert Chen",
            "email": "albert@hypervel.org"
        }
    ],
    "support": {
        "issues": "https://github.com/hypervel/components/issues",
        "source": "https://github.com/hypervel/components"
    },
    "autoload": {
        "psr-4": {
            "Hypervel\\Session\\": "src/"
        },
        "files": [
            "src/Functions.php"
        ]
    },
    "require": {
        "php": "^8.2",
        "ext-session": "*",
        "hyperf/context": "dev-3.2",
        "hyperf/collection": "dev-3.2",
        "hyperf/support": "dev-3.2",
        "hyperf/stringable": "dev-3.2",
        "hyperf/macroable": "dev-3.2",
        "hyperf/tappable": "dev-3.2",
        "hyperf/view-engine": "dev-3.2",
        "hypervel/cache": "dev-main",
        "hypervel/cookie": "dev-main",
        "hypervel/support": "dev-main"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "hyperf": {
            "config": "Hypervel\\Session\\ConfigProvider"
        },
        "branch-alias": {
            "dev-main": "0.1-dev"
        }
    },
    "repositories": [
        {
            "type": "github",
            "url": "https://github.com/kingIZZZY/cache" 
        },
        {
            "type": "github",
            "url": "https://github.com/kingIZZZY/cookie" 
        },
        {
            "type": "github",
            "url": "https://github.com/kingIZZZY/support" 
        }
    ]
}
